# Public site URL (used for SEO, sitemap, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://amitmohanty.vercel.app

# EmailJS credentials for the contact form (https://www.emailjs.com/)
# Create a free account, add an email service + template, then paste the IDs below.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Optional: visitor analytics (Vercel Analytics is auto-enabled on Vercel).
# Optional GitHub username override for the GitHub activity widget.
NEXT_PUBLIC_GITHUB_USERNAME=amitmohanty022
