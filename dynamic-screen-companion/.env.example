# Copy to .env and fill in. All values are optional — the app runs in
# MOCK mode without a Gemini key so it works out of the box.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OCR
# TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=eng

# Text-to-speech
TTS_ENABLED=true
TTS_LANGUAGE=en

# Server
HOST=0.0.0.0
PORT=8000
